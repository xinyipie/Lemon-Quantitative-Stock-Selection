# Environment variable example
#
# Do not commit real API keys. Keep real values in your shell, user environment,
# or a local .env file that is ignored by Git.

# Tushare API token
TUSHARE_TOKEN=your_tushare_token_here

# DeepSeek API key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: DashScope API key if you switch AI_CONFIG back to Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Windows PowerShell:
#   $env:TUSHARE_TOKEN="your_token"
#   $env:DEEPSEEK_API_KEY="your_key"
#
# Windows CMD:
#   set TUSHARE_TOKEN=your_token
#   set DEEPSEEK_API_KEY=your_key
#
# Linux/Mac:
#   export TUSHARE_TOKEN="your_token"
#   export DEEPSEEK_API_KEY="your_key"
