#!/usr/bin/env bash
set -uo pipefail

exec 9>/run/lock/stock-daily-full-update.lock
/usr/bin/flock -n 9 || exit 0

cd /opt/stock
set -a
. /opt/stock/.env
set +a

mkdir -p /opt/stock/logs
command_json='["/opt/stock/.venv/bin/python", "daily_web_update.py", "--mode", "full"]'
exec /opt/stock/.venv/bin/python -m web_app.services.update_worker \
  "$command_json" \
  "data/web_update_status.json" \
  >> /opt/stock/logs/daily_full_update.log 2>&1
